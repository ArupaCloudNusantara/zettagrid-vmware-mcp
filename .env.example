# Zettagrid Cloud Director MCP Server Configuration

# Zone Configuration
ZETTAGRID_DEFAULT_ZONE=jakarta
ZETTAGRID_API_VERSION=39.1

# Zone-specific API Tokens — Australia
ZETTAGRID_API_TOKEN_SYDNEY=your-sydney-token
ZETTAGRID_API_TOKEN_MELBOURNE=your-melbourne-token
ZETTAGRID_API_TOKEN_PERTH=your-perth-token
ZETTAGRID_API_TOKEN_BRISBANE=your-brisbane-token
ZETTAGRID_API_TOKEN_ADELAIDE=your-adelaide-token
ZETTAGRID_API_TOKEN_DARWIN=your-darwin-token

# Zone-specific API Tokens — Indonesia (fork addition)
ZETTAGRID_API_TOKEN_JAKARTA=your-jakarta-token
ZETTAGRID_API_TOKEN_CIBITUNG=your-cibitung-token

# NOTE: API and OAuth endpoints below are informational only.
# zone-manager.ts auto-generates the actual endpoints from the zone code map:
#   AU zones: https://mycloud.{code}.zettagrid.com/api
#   ID zones: https://mycloud-{code}.zettagrid.id/api  (fork addition)

# Zone API Endpoints — Australia
ZETTAGRID_API_ENDPOINT_SYDNEY=https://mycloud.syd.zettagrid.com/api
ZETTAGRID_API_ENDPOINT_MELBOURNE=https://mycloud.mel.zettagrid.com/api
ZETTAGRID_API_ENDPOINT_PERTH=https://mycloud.per.zettagrid.com/api
ZETTAGRID_API_ENDPOINT_BRISBANE=https://mycloud.bri.zettagrid.com/api
ZETTAGRID_API_ENDPOINT_ADELAIDE=https://mycloud.ade.zettagrid.com/api
ZETTAGRID_API_ENDPOINT_DARWIN=https://mycloud.dwn.zettagrid.com/api

# Zone API Endpoints — Indonesia (fork addition)
ZETTAGRID_API_ENDPOINT_JAKARTA=https://mycloud-jkt.zettagrid.id/api
ZETTAGRID_API_ENDPOINT_CIBITUNG=https://mycloud-cbt.zettagrid.id/api

# Zone OAuth Endpoints — Australia
ZETTAGRID_OAUTH_ENDPOINT_SYDNEY=https://mycloud.syd.zettagrid.com/oauth/tenant/your-organization-name/token
ZETTAGRID_OAUTH_ENDPOINT_MELBOURNE=https://mycloud.mel.zettagrid.com/oauth/tenant/your-organization-name/token
ZETTAGRID_OAUTH_ENDPOINT_PERTH=https://mycloud.per.zettagrid.com/oauth/tenant/your-organization-name/token
ZETTAGRID_OAUTH_ENDPOINT_BRISBANE=https://mycloud.bri.zettagrid.com/oauth/tenant/your-organization-name/token
ZETTAGRID_OAUTH_ENDPOINT_ADELAIDE=https://mycloud.ade.zettagrid.com/oauth/tenant/your-organization-name/token
ZETTAGRID_OAUTH_ENDPOINT_DARWIN=https://mycloud.dwn.zettagrid.com/oauth/tenant/your-organization-name/token

# Zone OAuth Endpoints — Indonesia (fork addition)
ZETTAGRID_OAUTH_ENDPOINT_JAKARTA=https://mycloud-jkt.zettagrid.id/oauth/tenant/your-organization-name/token
ZETTAGRID_OAUTH_ENDPOINT_CIBITUNG=https://mycloud-cbt.zettagrid.id/oauth/tenant/your-organization-name/token

# Organization Configuration
ZETTAGRID_ORGANIZATION=your-organization-name

# Performance Settings
ZETTAGRID_TIMEOUT=30000
ZETTAGRID_RETRY_ATTEMPTS=3
ZETTAGRID_ENABLE_CACHING=true

# Debug Settings
DEBUG_LEVEL=info
ZETTAGRID_DEBUG=false

# Transport (fork addition)
# "stdio" — for Claude Desktop / Cursor (subprocess mode, default)
# "http"  — for Docker deployment (remote access via Tailscale or SSH tunnel)
TRANSPORT=stdio
PORT=3001

# Live integration test IDs — only needed when running test-*.mjs scripts
# Get these values from your VDC: list_vdcs, list_edge_gateways, list_vapps, list_vms, list_catalogs
ZETTAGRID_TEST_VDC_ID=your-vdc-uuid
ZETTAGRID_TEST_GW_ID=your-edge-gateway-uuid
ZETTAGRID_TEST_VM_ID=your-production-vm-uuid
ZETTAGRID_TEST_VAPP_ID=your-production-vapp-uuid
ZETTAGRID_TEST_CATALOG_ID=your-catalog-uuid